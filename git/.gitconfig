[user]
	name = your-github-username
	email = your@email.com

[core]
	editor = nano
	autocrlf = input
	excludesfile = ~/.gitignore_global

[pull]
	rebase = false

[push]
	default = current

[alias]
	st = status
	co = checkout
	br = branch
	lg = log --oneline --graph --decorate
	undo = reset HEAD~1 --mixed
	amend = commit --amend --no-edit

[color]
	ui = auto

[init]
	defaultBranch = main
